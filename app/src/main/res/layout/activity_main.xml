<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="20dp"
    android:paddingBottom="12dp"
    android:background="#1a1a2e">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="18dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TG WS Proxy"
                android:textSize="22sp"
                android:textColor="#e0e0e0"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MTProto WebSocket Bridge  •  © DaniRev Studio  •  v1.0.2"
                android:textSize="11sp"
                android:textColor="#555"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="⚙"
            android:textSize="18sp"
            android:backgroundTint="#16213e"
            android:textColor="#7eb8f7"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"/>
    </LinearLayout>

    <!-- Status card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#16213e"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Остановлен"
                    android:textColor="#e0e0e0"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Host / Port row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="АДРЕС" android:textColor="#555" android:textSize="10sp" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/hostText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="127.0.0.1" android:textColor="#ccc" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ПОРТ" android:textColor="#555" android:textSize="10sp" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/portText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1443" android:textColor="#ccc" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Secret -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SECRET" android:textColor="#555" android:textSize="10sp" android:letterSpacing="0.08"/>
            <TextView android:id="@+id/secretText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="(авто)" android:textColor="#7eb8f7" android:textSize="12sp" android:fontFamily="monospace"/>

            <!-- Traffic row — visible only when running -->
            <LinearLayout
                android:id="@+id/trafficRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:visibility="gone">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↑ ОТПРАВЛЕНО" android:textColor="#555" android:textSize="10sp" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/trafficUp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0B" android:textColor="#4caf50" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↓ ПОЛУЧЕНО" android:textColor="#555" android:textSize="10sp" android:letterSpacing="0.08"/>
                    <TextView android:id="@+id/trafficDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0B" android:textColor="#2196F3" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/autostartBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Автозапуск включён"
                android:textColor="#4caf50"
                android:textSize="11sp"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Link card — visible only when running -->
    <androidx.cardview.widget.CardView
        android:id="@+id/linkCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#0d2a4a"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ССЫЛКА ПОДКЛЮЧЕНИЯ"
                android:textColor="#7eb8f7"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/linkText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#b0d4ff"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp"/>

            <!-- Three action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnConnectTg"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:text="▶ Подключить TG"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1976D2"
                    android:textColor="#ffffff"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnCopyLink"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Копировать"
                    android:textSize="11sp"
                    android:backgroundTint="#1a3a5c"
                    android:textColor="#7eb8f7"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Start / Stop buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="▶  Запустить"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#2196F3"
            android:textColor="#ffffff"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="■  Остановить"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#37474f"
            android:textColor="#90a4ae"
            android:enabled="false"/>
    </LinearLayout>

    <!-- Log output -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#4caf50"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:background="#0a0a0a"/>
    </ScrollView>


    <!-- Copyright footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© DaniRev Studio"
        android:textColor="#333"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"/>

</LinearLayout>